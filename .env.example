# ============================================
# XIB (Security in a Box) — Umbrella Config
# ============================================
# XIB is self-contained; no submodule environment files are required.
# ============================================

# ==================== XIB Grafana ====================
XIB_GRAFANA_PORT=4000
XIB_GRAFANA_PASSWORD=CHANGE_ME
XIB_GRAFANA_USER=admin
XIB_RETENTION=90d
VIB_SCAN_INTERVAL_HOURS=6
CIB_SCAN_INTERVAL_HOURS=6
TIB_SYNC_INTERVAL_HOURS=6
# Comma-separated registry images for VIB/CIB to inspect.
XIB_SCAN_IMAGES=
# Optional direct-socket troubleshooting bypass. Linux: stat -c '%g' /var/run/docker.sock
DOCKER_GID=
# Optional profiles: docker compose --profile pki --profile identity up -d
PIB_ENDPOINTS=
AUTHENTIK_URL=http://host.docker.internal:9000
AUTHENTIK_TOKEN=

# ==================== Grafana SSO (via Authentik/IIB) ====================
# Set by `make setup-sso` — do not set manually.
GRAFANA_SSO_ENABLED=false
GRAFANA_SSO_AUTO_LOGIN=false
AUTHENTIK_GRAFANA_CLIENT_ID=
AUTHENTIK_GRAFANA_CLIENT_SECRET=

# ==================== PIB OIDC (via Authentik/IIB) ====================
# Set by `make setup-sso` — do not set manually.
AUTHENTIK_STEPCA_CLIENT_ID=
AUTHENTIK_STEPCA_CLIENT_SECRET=

# ==================== Integration settings ====================
# External URL where the browser can reach Authentik (IIB).
# Used for OAuth redirect URLs in Grafana.
AUTHENTIK_EXTERNAL_URL=http://localhost:9080

# Hostname used when building Grafana redirect URIs for the Authentik app.
# Change this to your homelab hostname if not running on localhost.
XIB_HOST=localhost

# Network exposure (127.0.0.1 is safe for local demos; set 0.0.0.0 for LAN exposure)
BIND_ADDR=127.0.0.1
# Prefix for deterministic Docker container names. Change it for parallel stacks.
XIB_CONTAINER_PREFIX=xib

# SIB is part of the main Compose application. Clear this value to omit the
# privileged Linux runtime-security services from a Docker deployment.
COMPOSE_PROFILES=sib
SIB_CONTAINER_PREFIX=sib
SIB_STORAGE_BIND=127.0.0.1
SIB_VICTORIALOGS_PORT=9428
SIB_VICTORIAMETRICS_PORT=8429
SIB_SIDEKICK_BIND=127.0.0.1
SIB_SIDEKICK_PORT=2801
SIB_LOG_RETENTION=168h
SIB_METRICS_RETENTION=15d
