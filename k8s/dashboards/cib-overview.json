{
  "uid": "cib-overview",
  "title": "CIB — Compliance Overview",
  "description": "Container policy, license compliance, and EOL base image tracking",
  "tags": ["cib", "compliance", "security"],
  "refresh": "5m",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Policy Violations",
      "description": "Total container policy violations (privileged, root user, resource limits…)",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "cib-vm" },
        "expr": "last_over_time(cib_total_policy_violations[8h])",
        "legendFormat": "Violations",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "EOL Base Images",
      "description": "Running images built on an end-of-life OS",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "cib-vm" },
        "expr": "last_over_time(cib_eol_images_total[8h])",
        "legendFormat": "EOL Images",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "License Violations",
      "description": "Images with copyleft or denied licenses in their SBOM",
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "cib-vm" },
        "expr": "sum(last_over_time(cib_license_violations_total[8h])) or vector(0)",
        "legendFormat": "License Violations",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Images Checked",
      "gridPos": { "h": 4, "w": 4, "x": 15, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "text" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] },
          "mappings": []
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "cib-vm" },
        "expr": "last_over_time(cib_images_checked_total[8h])",
        "legendFormat": "Images",
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Last Scan",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsLocal",
          "color": { "mode": "fixed", "fixedColor": "text" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] },
          "mappings": []
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "cib-vm" },
        "expr": "cib_last_scan_timestamp",
        "legendFormat": "Last Scan",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Container Policy Violations",
      "description": "CIS-aligned container configuration checks — 1 = violation",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "options": {
        "sortBy": [{ "displayName": "Violations", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "container" }, "properties": [{ "id": "displayName", "value": "Container" }] },
          { "matcher": { "id": "byName", "options": "check" }, "properties": [{ "id": "displayName", "value": "Check" }] },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Result" },
              { "id": "custom.width", "value": 100 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "PASS", "color": "green", "index": 0 }, "1": { "text": "FAIL", "color": "red", "index": 1 } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true }, "indexByName": {}, "renameByName": {} } }
      ],
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "cib-vm" },
        "expr": "last_over_time(cib_policy_violation[8h])",
        "instant": true,
        "legendFormat": "",
        "refId": "A",
        "format": "table"
      }]
    },
    {
      "id": 7,
      "type": "table",
      "title": "EOL Base Images",
      "description": "Containers built on end-of-life operating systems",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "options": { "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "image" }, "properties": [{ "id": "displayName", "value": "Image" }] },
          { "matcher": { "id": "byName", "options": "os" }, "properties": [{ "id": "displayName", "value": "OS" }] },
          { "matcher": { "id": "byName", "options": "version" }, "properties": [{ "id": "displayName", "value": "Version" }] },
          { "matcher": { "id": "byName", "options": "eol_date" }, "properties": [{ "id": "displayName", "value": "EOL Date" }] },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "EOL" },
              { "id": "custom.width", "value": 80 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "Supported", "color": "green", "index": 0 }, "1": { "text": "EOL", "color": "red", "index": 1 } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true }, "indexByName": {}, "renameByName": {} } }
      ],
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "cib-vm" },
        "expr": "last_over_time(cib_image_eol[8h])",
        "instant": true,
        "legendFormat": "",
        "refId": "A",
        "format": "table"
      }]
    },
    {
      "id": 8,
      "type": "table",
      "title": "License Violations",
      "description": "SBOM components with denied licenses (copyleft / policy violations)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "options": { "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "image" }, "properties": [{ "id": "displayName", "value": "Image" }] },
          { "matcher": { "id": "byName", "options": "package" }, "properties": [{ "id": "displayName", "value": "Package" }] },
          { "matcher": { "id": "byName", "options": "version" }, "properties": [{ "id": "displayName", "value": "Version" }] },
          {
            "matcher": { "id": "byName", "options": "license" },
            "properties": [
              { "id": "displayName", "value": "License" },
              {
                "id": "links",
                "value": [{ "title": "SPDX", "url": "https://spdx.org/licenses/${__value.raw}.html" }]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              { "id": "custom.width", "value": 100 },
              {
                "id": "mappings",
                "value": [{ "type": "value", "options": { "1": { "text": "VIOLATION", "color": "red", "index": 0 } } }]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true }, "indexByName": {}, "renameByName": {} } }
      ],
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "cib-vm" },
        "expr": "last_over_time(cib_license_violation[8h])",
        "instant": true,
        "legendFormat": "",
        "refId": "A",
        "format": "table"
      }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Compliance Trend",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "cib-vm" },
          "expr": "cib_total_policy_violations",
          "legendFormat": "Policy Violations",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "cib-vm" },
          "expr": "cib_eol_images_total",
          "legendFormat": "EOL Images",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "cib-vm" },
          "expr": "sum(cib_license_violations_total) or vector(0)",
          "legendFormat": "License Violations",
          "refId": "C"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": []
}
