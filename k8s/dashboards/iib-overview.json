      "datasource": { "type": "prometheus", "uid": "iib-vm" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "semi-dark-purple", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "semi-dark-purple", "value": null }]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "iib-vm" },
          "expr": "last_over_time(iib_providers_total[8h])",
          "legendFormat": "Providers",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Last Sync",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "iib-vm" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "dateTimeAsLocal",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "iib-vm" },
          "expr": "last_over_time(iib_last_sync_timestamp[8h])",
          "legendFormat": "Last Sync",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Groups",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "iib-vm" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "light-blue", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "light-blue", "value": null }]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "iib-vm" },
          "expr": "last_over_time(iib_groups_total[8h])",
          "legendFormat": "Groups",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Login Events Over Time",
      "gridPos": { "h": 8, "w": 14, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "iib-vm" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failures" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Logins" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "iib-vm" },
          "expr": "iib_logins_total",
          "legendFormat": "Logins",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "iib-vm" },
          "expr": "iib_login_failures_total",
          "legendFormat": "Failures",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "User Count Over Time",
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "iib-vm" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Total" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Active" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "iib-vm" },
          "expr": "iib_users_total",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "iib-vm" },
          "expr": "iib_users_active",
          "legendFormat": "Active",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "Outpost Health",
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "iib-vm" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "options": { "0": { "color": "red", "index": 0, "text": "Unhealthy" } }, "type": "value" },
                  { "options": { "1": { "color": "green", "index": 1, "text": "Healthy" } }, "type": "value" }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Value" }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "iib-vm" },
          "expr": "last_over_time(iib_outpost_healthy[8h])",
          "instant": true,
          "legendFormat": "{{name}}",
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "name": "Name",
              "type": "Type",
              "Value": "Status"
            }
          }
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["iib", "identity", "authentik"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "IIB — Identity Overview",
  "uid": "iib-overview",
  "version": 1
}
